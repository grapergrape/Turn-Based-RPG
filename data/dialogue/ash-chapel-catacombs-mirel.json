    "jarik": {
      "lines": [
        "\"Jarik can mend a pump with wire, prayer, and insults aimed at the pump's ancestors.\"",
        "\"He went to Hallowfen because wall pay spends better than chapel gratitude. I told him gratitude has fewer teeth. He said teeth do not buy boots.\""
      ],
      "choices": [
        {
          "label": "He sounds useful",
          "next": "useful"
        },
        {
          "label": "He sounds stubborn",
          "next": "stubborn"
