    "necklace": {
      "lines": [
        "\"No blessing on it. Do not let a priest charge you for that lie.\"",
        "\"Cheap tin saint, worn smooth by three fevers and one roof collapse. Luck is memory with a better coat.\""
      ],
      "choices": [
        {
          "label": "That still matters",
          "next": "matters"
