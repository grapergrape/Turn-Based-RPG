    "start": {
      "lines": [
        "The ledger is written as lessons, not confession, in a careful teaching hand.",
        "At the head of the first page: THE CHOIR OF THE OPEN WOUND. You have broken cults along the ash roads and never seen that name."
      ],
      "effects": {
        "setFlag": "ash-chapel-choir-named"
      },
