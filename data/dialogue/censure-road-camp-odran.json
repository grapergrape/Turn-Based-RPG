{
  "id": "censure-road-camp-odran",
  "title": "Father Augustine",
  "nodes": {
    "start": {
      "conditions": {
        "flag": "censure-road-confession-absolved"
      },
      "else": "start-open",
      "lines": [
        "Father Augustine sits beside the confession screen with a locked cup, a stamp pad, and the exhausted look of a man who has forgiven too many receipts.",
        "\"You are absolved for road purposes. Do not spend the condition all in one place.\""
      ],
      "choices": [
        {
          "label": "Confront him about last bell",
          "conditions": {
            "flag": "odran-late-visit-seen",
            "flagsAbsent": ["odran-late-visit-resolved"]
          },
          "next": "late-visit-confront-widow"
        },
        {
          "label": "Ask who commands this camp",
          "next": "command"
        },
        {
          "label": "Leave Father Augustine",
          "close": true
        }
      ]
    },
    "start-open": {
      "lines": [
        "Father Augustine sits beside the confession screen with a coin scale on his knee and a tiny knife for cutting paper chits.",
        "\"Cult-breaker. Chapel dust on your boots, Ash Road grief in your coat, and no confession on my slate. Sit before the sins organize.\""
      ],
      "choices": [
        {
          "label": "Confront him about last bell",
          "conditions": {
            "flag": "odran-late-visit-seen",
            "flagsAbsent": ["odran-late-visit-resolved"]
          },
          "next": "late-visit-confront-widow"
        },
        {
          "label": "Seek road absolution",
          "next": "absolution-routes"
        },
        {
          "label": "Ask how sins are priced",
          "conditions": {
            "flagsAbsent": ["odran-late-visit-seen"]
          },
          "next": "rules"
        },
        {
          "label": "Ask who commands this camp",
          "next": "command"
        },
        {
          "label": "Leave Father Augustine",
          "close": true
        }
      ]
    },
    "rules": {
      "lines": [
        "\"Road absolution is not comfort work. You name the thing, pay enough to remember it, and I write down how much courage was left afterward.\"",
        "\"Five ducats settles a standard field soul. If your purse is short, you pray the difference. If you claim poverty while it clinks, I add a ducat for insulting both of us.\""
      ],
      "choices": [
        {
          "label": "Seek road absolution",
          "next": "absolution-routes"
        },
        {
          "label": "Leave the screen",
          "close": true
        }
      ]
    },
    "command": {
      "lines": [
        "\"Aquila commands hands, routes, and the little chalk arrows that keep novices from marching into latrines.\"",
        "\"I am the priest assigned to the road office. Father-Censor Decian reads my reports when a courier survives long enough to carry ink. Do not look relieved. Decian reads margins like wounds.\""
      ],
      "choices": [
        {
          "label": "Ask how supplies move",
          "next": "supplies"
        },
        {
          "label": "Leave Father Augustine",
          "close": true
        }
      ]
    },
    "supplies": {
      "lines": [
        "\"Ruth holds issue stock: bandages, meal, shot, clean hooks, black thread. A bell mark opens the right crate, a seal opens the good crate, and a believable emergency opens her temper.\"",
        "\"Judith sells what the Office forgot to send. This is called private enterprise because theft sounded rude on the quartermaster forms.\""
      ],
      "choices": [
        {
          "label": "Seek road absolution",
          "next": "absolution-routes"
        },
        {
          "label": "Ask who commands this camp",
          "next": "command"
        },
        {
          "label": "Leave Father Augustine",
          "close": true
        }
      ]
    },
    "absolution-routes": {
      "lines": [
        "Augustine squares the stamp beside the locked cup.",
        "\"The long record takes coin or prayer. The short road needs something Decian would accept. Bring me a rule or an account. A good lie may pass, but Decian reads ink.\""
      ],
      "choices": [
        {
          "label": "Give the full road confession",
          "next": "confession-begin"
        },
        {
          "label": "Invoke service under writ",
          "conditions": {
            "flagsAbsent": ["censure-road-confession-absolved"],
            "fieldRatings": {
              "doctrine": 45
            }
          },
          "effects": {
            "setFlag": [
              "censure-road-confession-absolved",
              "odran-confession-doctrine-route"
            ],
            "inventory": {
              "add": [
                { "item": "censure-absolution-chit", "count": 1 }
              ]
            },
            "questUpdate": {
              "quest": "censure-road-confession",
              "stage": "absolved-by-doctrine"
            },
            "log": "Augustine accepts service under writ and stamps the absolution chit."
          },
          "next": "absolved-doctrine"
        },
        {
          "label": "Trade him a clean field account",
          "conditions": {
            "flagsAbsent": ["censure-road-confession-absolved"],
            "fieldRatings": {
              "speech": 45
            }
          },
          "effects": {
            "setFlag": [
              "censure-road-confession-absolved",
              "odran-confession-speech-route"
            ],
            "inventory": {
              "add": [
                { "item": "censure-absolution-chit", "count": 1 }
              ]
            },
            "questUpdate": {
              "quest": "censure-road-confession",
              "stage": "absolved-by-account"
            },
            "log": "Augustine keeps the field account and stamps the absolution chit."
          },
          "next": "absolved-account"
        },
        {
          "label": "Bury the fee in a dead-letter line",
          "conditions": {
            "flagsAbsent": ["censure-road-confession-absolved"],
            "fieldRatings": {
              "guile": 55
            }
          },
          "effects": {
            "setFlag": [
              "censure-road-confession-absolved",
              "odran-confession-guile-route",
              "odran-confession-false-record-risk"
            ],
            "inventory": {
              "add": [
                { "item": "censure-absolution-chit", "count": 1 }
              ]
            },
            "questUpdate": {
              "quest": "censure-road-confession",
              "stage": "absolved-by-false-record"
            },
            "log": "You hide Augustine's fee in a dead-letter line. The absolution chit carries a clean stamp."
          },
          "next": "absolved-false-record"
        },
        {
          "label": "Leave the stamp alone",
          "close": true
        }
      ]
    },
    "confession-begin": {
      "lines": [
        "Augustine pulls the canvas screen between you. His silhouette sharpens around the coin scale.",
        "\"Kneel if you want ceremony, or sit if your knees have field sense. I will read the road back while you answer for Heaven and my ledger; the ledger is less forgiving.\""
      ],
      "choices": [
        {
          "label": "Begin the record",
          "next": "chapel-record-start"
        },
        {
          "label": "Leave the screen",
          "close": true
        }
      ]
    },
    "chapel-record-start": {
      "lines": [
        "\"Ash Chapel first. The road office trains you to notice blood, doctrine, doors, and excuses. It does not train the blood to stop noticing you.\""
      ],
      "choices": [
        {
          "label": "Answer for Ash Chapel",
          "next": "chapel-cult-broken"
        }
      ]
    },
    "chapel-cult-broken": {
      "conditions": {
        "flag": "ash-chapel-cult-broken"
      },
      "else": "chapel-martyr-ended",
      "lines": [
        "\"You broke the chapel cell. Armed cultists, broken rite, bodies enough for a clerk to ask for a second clerk.\"",
        "\"Killing a cell is field duty. I still write it down. Ink enjoys blood too much to be trusted alone.\""
      ],
      "choices": [
        {
          "label": "Confess breaking the cell",
          "next": "chapel-martyr-ended"
        }
      ]
    },
    "chapel-martyr-ended": {
      "conditions": {
        "flag": "nave-cross-martyr-ended"
      },
      "else": "chapel-cellar-victim-ended",
      "lines": [
        "\"You cut down the opened man behind the altar.\"",
        "\"Mercy is a knife with excellent manners. Keep it sharp and stop pretending it is clean.\""
      ],
      "choices": [
        {
          "label": "Confess cutting him down",
          "next": "chapel-cellar-victim-ended"
        }
      ]
    },
    "chapel-cellar-victim-ended": {
      "conditions": {
        "flag": "cellar-victim-ended"
      },
      "else": "chapel-bell-rung",
      "lines": [
        "\"You ended the bound one in the cold room before the cult could make a second saint.\"",
        "\"Good. Also terrible. Most field work is a pair of boots named Good and Terrible.\""
      ],
      "choices": [
        {
          "label": "Confess the cold room",
          "next": "chapel-bell-rung"
        }
      ]
    },
    "chapel-bell-rung": {
      "conditions": {
        "flag": "ash-chapel-bell-rung"
      },
      "else": "road-record-start",
      "lines": [
        "\"You rang the chapel bell and told the Remnant the house could be entered.\"",
        "\"Pride costs extra only when it sings, and the bell did the singing. I can offer a small discount.\""
      ],
      "choices": [
        {
          "label": "Confess ringing the bell",
          "next": "road-record-start"
        }
      ]
    },
    "road-record-start": {
      "lines": [
        "\"Now the Ash Road. The road has better ears than most bishops and worse manners than all of them.\""
      ],
      "choices": [
        {
          "label": "Answer for the Ash Road",
          "next": "road-garron-abused"
        }
      ]
    },
    "road-garron-abused": {
      "conditions": {
        "flag": "long-ash-crossroad-brother-abused"
      },
      "else": "road-edrin-mocked",
      "lines": [
        "\"You insulted Gideon Carbo while he was fixed into public usefulness.\"",
        "\"A road sign with feelings is an administrative trap. You stepped in it.\""
      ],
      "choices": [
        {
          "label": "Confess the insult",
          "next": "road-edrin-mocked"
        }
      ]
    },
    "road-edrin-mocked": {
      "conditions": {
        "flag": "long-ash-field-brother-mocked"
      },
      "else": "road-holt-house-known",
      "lines": [
        "\"You mocked Eleazar Carbo in the wheat.\"",
        "\"He called himself royalty? That is evidence for mercy, not permission.\""
      ],
      "choices": [
        {
          "label": "Confess the mockery",
          "next": "road-holt-house-known"
        }
      ]
    },
    "road-holt-house-known": {
      "conditions": {
        "questStages": {
          "calcified-brothers": "complete"
        }
      },
      "else": "road-family-lie",
      "lines": [
        "\"The Carbo house kept two calcified great-granduncles as tools until custom learned to call itself care.\"",
        "\"Then the Choir found the habit and called it an altar.\""
      ],
      "choices": [
        {
          "label": "Confess the Carbo house",
          "next": "road-family-lie"
        }
      ]
    },
    "road-family-lie": {
      "conditions": {
        "flag": "long-ash-field-family-lie"
      },
      "else": "road-family-truth",
      "lines": [
        "\"You told Eleazar the Carbo family was safe.\"",
        "\"Kind lies wear clean gloves. They still leave fingerprints.\""
      ],
      "choices": [
        {
          "label": "Confess the lie",
          "next": "road-wolves-evidence"
        }
      ]
    },
    "road-family-truth": {
      "conditions": {
        "flag": "long-ash-field-family-truth"
      },
      "else": "road-wolves-evidence",
      "lines": [
        "\"You told Eleazar the family was dead.\"",
        "\"Truth is not free because it is correct. It spends the listener.\""
      ],
      "choices": [
        {
          "label": "Confess the truth",
          "next": "road-wolves-evidence"
        }
      ]
    },
    "road-wolves-evidence": {
      "conditions": {
        "flag": "long-ash-wolves-avenged-family"
      },
      "else": "record-summary",
      "lines": [
        "\"You found the torn cult cloth by the wolves.\"",
        "\"The pack judged faster than we could invoice it. Humbling.\""
      ],
      "choices": [
        {
          "label": "Confess the wolves",
          "next": "record-summary"
        }
      ]
    },
    "record-summary": {
      "lines": [
        "\"That is the record the road has coughed up.\"",
        "\"If I missed one, do not smile. God has better paperwork than I do.\""
