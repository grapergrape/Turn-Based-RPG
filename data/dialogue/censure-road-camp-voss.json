    "ash-chapel-evidence-received": {
      "lines": [
        "Aquila folds the soot-marked evidence into waxed cloth. Her field seal bites through both layers.",
        "\"I will see this reaches the Remnant. Augustine does not touch the packet, and the field credit goes under your name.\""
      ],
      "choices": [
        {
          "label": "Leave the packet with Aquila",
          "next": "main"
        }
      ]
    },
    "main": {
      "lines": [
        "Preceptor Aquila has slates pinned under one boot and mud on both cuffs.",
        "\"If Cyprian calls this a camp again, make him count latrine nails. A camp has rest. This has paperwork with damp corners.\""
      ],
      "choices": [
        {
          "label": "Request Hallowfen route clearance",
          "conditions": {
            "flagsAbsent": ["censure-road-voss-route-cleared"]
          },
          "next": "route-clearance"
        },
        {
          "label": "Ask about cult-breaker training",
          "next": "training"
        },
        {
          "label": "Ask about supplies and filed reports",
          "next": "supplies"
        },
        {
          "label": "Ask about the filed report",
          "conditions": {
            "flag": "censure-road-voss-report-perfect"
          },
          "next": "report-filed"
        },
        {
          "label": "Leave Aquila to the slates",
          "close": true
        }
      ]
    },
    "training": {
      "lines": [
        "\"New breakers learn bells before blades. A missed bell wastes a squad before the enemy gets a turn.\"",
        "\"After that, they learn how to stand still while a farmer begs for mercy with someone else's mouth.\""
      ],
      "choices": [
        {
          "label": "Leave Aquila to the drill yard",
          "close": true
        }
      ]
    },
    "supplies": {
      "lines": [
        "\"Ruth issues what the writ allows. Judith sells what the writ forgot. Everyone calls that corruption until they need dry beans.\"",
        "\"The road survives on doctrine, wax seals, and people pretending the third column in the ledger does not exist.\""
      ],
      "choices": [
        {
          "label": "Give Aquila the graveyard censure report",
          "conditions": {
            "flags": [
              "heard-bell-resolved-censure",
              "heard-bell-censure-report-filed"
            ],
            "flagsAbsent": [
              "heard-bell-censure-report-acknowledged"
            ]
          },
          "next": "heard-bell-censure-report"
        },
        {
          "label": "Lay out the corrected peal order",
          "conditions": {
            "flag": "censure-road-preceptor-route-order-found",
            "flagsAbsent": ["censure-road-voss-preceptor-order-reported"]
          },
          "effects": {
            "setFlag": "censure-road-voss-preceptor-order-reported",
            "log": "Aquila files the altered peal order as an unauthorized correction."
          },
          "next": "preceptor-order"
        },
        {
          "label": "Give Aquila the missing-witness reading",
          "conditions": {
            "flag": "censure-road-preceptor-route-correction-read",
            "flagsAbsent": ["censure-road-voss-preceptor-correction-reported"]
          },
          "effects": {
            "setFlag": "censure-road-voss-preceptor-correction-reported",
            "log": "Aquila records the missing witness as proof that the peal correction lacked authority."
          },
          "next": "preceptor-correction"
        },
        {
          "label": "Report what was hidden in Augustine's chest",
          "conditions": {
            "flags": [
              "odran-late-visit-suspected",
              "censure-road-odran-chest-linen-found"
