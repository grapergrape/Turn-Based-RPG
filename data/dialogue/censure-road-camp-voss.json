            "flagsAbsent": ["censure-road-voss-odran-chest-reported"]
          },
          "effects": {
            "setFlag": "censure-road-voss-odran-chest-reported",
            "log": "Aquila opens a watch entry for Father Augustine's tent."
          },
          "next": "odran-chest"
        },
        {
          "label": "Leave Aquila to the ledgers",
          "close": true
        }
      ]
    },
    "heard-bell-censure-report": {
      "lines": [
        "Aquila reads the twelve names without moving her pencil. She turns the page over before she marks the graveyard coordinates.",
        "\"Eleven standing subjects and one destroyed below ground. Old office knowledge, never recalled. I can file the purgation request, but I will not call this a clean inheritance.\"",
        "\"Judith will issue the road bundle. The writ covers one burn. It does not make the fire wise.\""
      ],
      "choices": [
        {
          "label": "Leave the report with Aquila",
          "effects": {
            "setFlag": "heard-bell-censure-report-acknowledged",
            "log": "Aquila seals the graveyard report and sends the issue order to Judith."
          },
          "close": true
        },
        {
          "label": "Keep the report for now",
          "close": true
        }
      ]
    },
    "preceptor-order": {
      "lines": [
        "Aquila fits the loose correction against the punctures in her original order.",
        "\"The holes and thread match my bundle. This page was tied in before the file closed, then moved behind my seal. Leave it here.\""
      ],
      "choices": [
        {
          "label": "Leave the altered order with Aquila",
          "close": true
        }
      ]
    },
    "preceptor-correction": {
      "lines": [
        "Aquila reads the altered return-peal clause twice, then circles the empty witness line.",
        "\"Alarm duty without a named breach witness is not a correction. It is an order written after the fact. I will find who taught my file to lie.\""
      ],
      "choices": [
        {
          "label": "Leave the doctrinal reading with Aquila",
          "close": true
        }
      ]
    },
    "odran-chest": {
      "lines": [
        "Aquila listens with her pencil held off the slate.",
        "\"A woman's linen in Augustine's travel chest is cause for a watch, not a charge. Use the confession screen after last bell. Bring me the name you see at his rope.\""
      ],
      "choices": [
        {
          "label": "Leave the watch entry open",
          "close": true
        }
      ]
    },
    "report-filed": {
      "lines": [
        "\"Your report survived the red pencil. That does not make you holy, but it does make you rare.\"",
        "\"Judith has your issue bundle. If she argues, tell her I can count her beans louder than she can sell them.\""
      ],
      "choices": [
        {
          "label": "Leave Aquila to the filed slates",
          "close": true
        }
      ]
    },
