            "inventory": {
              "add": [
                {
                  "item": "book-of-kept-names",
                  "count": 1
                },
                {
                  "item": "mortuary-examination-docket",
                  "count": 1
                }
              ]
            },
            "questUpdate": {
              "quest": "those-who-heard-the-bell",
              "stage": "complete",
              "log": "Quest complete: Those Who Heard the Bell."
            },
            "log": "You wrap Keziah's register with the mortuary docket. Sapphira remains sealed below."
