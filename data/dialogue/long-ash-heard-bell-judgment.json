{
  "id": "long-ash-heard-bell-judgment",
  "title": "The Twelve Names",
  "nodes": {
    "start": {
      "conditions": {
        "flags": [
          "heard-bell-truth-joined",
          "heard-bell-sava-found"
        ]
      },
      "else": "incomplete",
      "lines": [
        "Keziah kept the names. The road office kept the measurements. Sapphira Rufa waits where both records point."
      ],
      "choices": [
        {
          "label": "Decide what the road will remember",
          "next": "unresolved",
          "close": false
        },
        {
          "label": "Wait before judging",
          "close": true
        }
      ]
    },
    "unresolved": {
      "conditions": {
        "flagsAbsent": [
          "heard-bell-resolved"
        ]
