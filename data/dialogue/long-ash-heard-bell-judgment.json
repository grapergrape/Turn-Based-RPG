          "close": true
        },
        {
          "label": "Take both records as evidence",
          "effects": {
            "setFlag": [
              "heard-bell-resolved",
              "heard-bell-resolved-evidence",
              "heard-bell-records-carried",
              "heard-bell-sava-left-sealed"
