            "inventory": {
              "add": [
                {
                  "item": "book-of-kept-names",
                  "count": 1
                },
                {
                  "item": "mortuary-examination-docket",
                  "count": 1
                }
              ]
            },
            "questUpdate": {
              "quest": "those-who-heard-the-bell",
              "stage": "complete",
              "log": "Quest complete: Those Who Heard the Bell."
            },
            "log": "You take both records. Sapphira's empty niche remains as part of their evidence."
