      "choices": [
        {
          "label": "Leave the report to travel",
          "close": true
        }
      ]
    },
    "resolved-evidence": {
      "lines": [
        "Keziah's register and the mortuary docket are in your pack. The road office no longer owns the only account."
      ],
      "choices": [
        {
          "label": "Carry the records north",
          "close": true
        }
      ]
    },
    "incomplete": {
      "lines": [
        "The two chapels keep different counts. There is not enough here yet to judge what happened to the missing name."
