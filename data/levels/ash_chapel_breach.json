  "codex": [
    {
      "id": "ashen-censure",
      "name": "The Ashen Censure",
      "kind": "Holy Remnant, field office",
      "summary": "The office you serve. The quiet arm of the Remnant that finds Host-cults and ends them before they spread, or before anyone starts asking why the rot still rises.",
      "facts": [
        "Sends cult-breakers down the ash roads on written writs.",
        "Thankless work. Many of the faithful find it distasteful.",
        "Lately the writs come faster than they used to, and the Office will not say why."
      ]
    },
    {
      "id": "the-host",
      "name": "The Host",
      "kind": "The rot. Hell's work, by doctrine.",
      "summary": "What the fires of the Descent left behind. It opens a body and rebuilds it in the shape of damnation: halos of bone, ribs spread like chapel doors, borrowed scripture in too many mouths.",
      "facts": [
        "Spreads by touch, by blood, and by contaminated relic-metal.",
        "Since the Stilling it no longer catches the way it did in the Bloom. An opening left alone tends to burn out unless something feeds it.",
        "Doctrine forbids asking why the Bloom ever stopped."
      ]
    },
    {
      "id": "choir-open-wound",
      "name": "The Choir of the Open Wound",
      "kind": "Host-cult. No Censure record.",
      "unlockedBy": { "questStage": { "investigate-ash-chapel-cult": "evidence-found" } },
      "summary": "The cult that took this chapel. They worship the rot and call its spread a kindness. You have never met the name on any writ, and that is what frightens you.",
      "facts": [
        "They call infection confession, and the opened ones icons, not monsters.",
        "They open only those they judge to be turning holy. The merely faithful they leave in the road, marked refuse.",
        "They feed a saint slowly, by hand, to keep it growing.",
        "They kept settlement guards for opening and moved the families before you arrived.",
        "Their ledger marks the Hallowfen wall as their next ground."
      ]
    },
    {
      "id": "penitent-engines",
      "name": "The Penitent Engines",
      "kind": "War-monks. Do not engage.",
      "unlockedBy": { "flag": "inspected-engine-rut" },
      "summary": "Warrior-monks who cut away their own flesh and seal the rest in machine, so the rot finds nothing to take. The old war-orders, never the Pontifex's. The Censure files them under do not engage.",
      "facts": [
        "One stood in this chapel's doorway, then turned and left without coming in.",
        "They do not abandon a route for nothing.",
        "By every record the roads keep, a Penitent cannot fall to the rot."
      ]
    }
  ],
  "journalNotes": [
    { "flag": "read-warden-journal", "text": "The warden's own book names this place Quarantine House Seventeen. After the Stilling it stopped holding the sick and began holding anyone who argued a tithe or asked the wrong question. The diocese let it be forgotten." },
    { "flag": "found-catacombs", "text": "Under-galleries run beneath the chapel, packed jaw to heel with the quarantine dead. The cult chose a house already taught to suffer." },
    { "flag": "inspected-engine-rut", "text": "A Penitent Engine stood in the doorway, then turned and left without coming inside. They do not abandon a route for nothing." }
  ],
