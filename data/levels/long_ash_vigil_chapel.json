              },
              "successLog": "The ring turns inside the stone. The panel releases without taking a chip.",
              "success": {
                "setFlag": [
                  "heard-bell-vigil-panel-opened",
                  "heard-bell-vigil-panel-opened-ring"
                ]
              }
            },
            {
              "id": "read-soot-seam",
              "label": "Read the soot-lined seam",
              "field": "search",
              "dc": 40,
              "successLog": "Finger wear marks the catch. It yields under steady pressure.",
              "failLog": "The soot breaks into old smears. The catch stays hidden.",
              "success": {
                "setFlag": [
                  "heard-bell-vigil-panel-opened",
                  "heard-bell-vigil-panel-opened-search"
                ]
              }
            },
            {
              "id": "restore-vigil-line",
              "label": "Restore the omitted vigil line",
              "field": "doctrine",
              "dc": 40,
              "successLog": "The missing prayer names a hand at the left edge. The prayer catch opens there.",
              "failLog": "The surviving words do not give up their order.",
              "success": {
                "setFlag": [
                  "heard-bell-vigil-panel-opened",
                  "heard-bell-vigil-panel-opened-doctrine"
                ]
              }
            },
            {
              "id": "force-panel",
              "label": "Force the fitted stone",
              "primary": "body",
              "dc": 4,
              "successLog": "The stone tears free. Paper catches under it and parts at the binding.",
              "failLog": "The stone bites into your palm and does not move.",
              "success": {
                "setFlag": [
                  "heard-bell-vigil-panel-opened",
                  "heard-bell-vigil-panel-forced",
                  "heard-bell-register-damaged"
                ]
              }
            }
          ]
        }
