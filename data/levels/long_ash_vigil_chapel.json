  "journalNotes": [
    {
      "flag": "heard-bell-register-read",
      "text": "Hessa Marr recorded deliberate responses from the calcified people in the graveyard."
    },
    {
      "flag": "heard-bell-docket-read",
      "text": "The road office measured those responses and filed them as settling."
    },
    {
      "flag": "heard-bell-truth-joined",
      "text": "Sava Rell reacted to Hallowfen before its bells sounded."
    },
    {
      "flag": "heard-bell-resolved-vigil",
      "text": "The twelve names remain together. The listening niche is quiet for now."
    },
    {
      "flag": "heard-bell-resolved-censure",
      "text": "The road office has the graveyard location. A purgation order will follow."
    },
    {
      "flag": "heard-bell-resolved-evidence",
      "text": "Hessa's register and the mortuary docket are in your pack."
    }
  ],
