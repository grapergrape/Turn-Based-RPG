        "x": 5,
        "y": 9,
        "facing": "se",
        "ambient": [
          "The second beat is mine. The third comes from the wall.",
          "Salome says fear is a door you can read from both sides.",
          "Do not let the lesson card hear my name."
        ],
        "dialogue": "south-measure-clinic-jalen-olt",
        "talkRadius": 1
      }
    ],
